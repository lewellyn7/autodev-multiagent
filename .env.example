# AI Gateway Configuration Example
# Copy to .env and fill in your values

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=your_secure_password

# Session
SESSION_KEY=your_random_session_key

# Database
DB_TYPE=sqlite
# DB_FILE=data/gateway.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/gateway

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
ADMIN_RATE_LIMIT=30

# OAuth (GitHub)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_secret
GITHUB_REDIRECT_URI=http://localhost:8000/oauth/github/callback

# Security
ENCRYPTION_KEY=your_32_byte_encryption_key
SECRET_KEY=your_secret_key

# CORS (comma-separated)
CORS_ORIGINS=*
