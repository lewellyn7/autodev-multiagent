# AI Gateway Configuration
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=28000
DEBUG=false

# -----------------------------------------------------------------------------
# Admin Credentials
# -----------------------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-in-production

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL - default for production)
# -----------------------------------------------------------------------------
DB_TYPE=postgres

# PostgreSQL Connection (used when DB_TYPE=postgres)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ai_gateway
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# SQLite (fallback, used when DB_TYPE=sqlite)
DB_FILE=data/gateway.db

# -----------------------------------------------------------------------------
# Note
# -----------------------------------------------------------------------------
# For local development with SQLite only (no PostgreSQL):
#   DB_TYPE=sqlite
#   docker compose up -d
#
# For production with PostgreSQL:
#   1. Set POSTGRES_PASSWORD to a strong password
#   2. docker compose up -d
